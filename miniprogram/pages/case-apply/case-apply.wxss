.apply-container { padding: 20rpx 30rpx 200rpx; }

.steps-card { padding: 30rpx; }
.steps-row { display: flex; justify-content: space-between; }
.step-item { flex: 1; text-align: center; }

.step-circle {
  width: 56rpx; height: 56rpx; line-height: 56rpx;
  border-radius: 50%; background: #f0f0f0; color: #999;
  font-size: 26rpx; margin: 0 auto 12rpx; font-weight: bold;
}

.step-circle.active { background: #1890ff; color: #fff; }

.step-label { font-size: 22rpx; color: #999; }
.step-label.active { color: #1890ff; font-weight: bold; }

.picker-view {
  background: #f5f7fa; border-radius: 12rpx;
  padding: 24rpx; font-size: 28rpx;
}

.upload-area {
  padding: 40rpx; text-align: center;
  border: 2rpx dashed #ddd; border-radius: 12rpx; margin-top: 20rpx;
}

.upload-plus { font-size: 60rpx; color: #999; display: block; }
.upload-text { font-size: 24rpx; color: #999; margin-top: 10rpx; }

.image-list { display: flex; flex-wrap: wrap; gap: 20rpx; margin-top: 20rpx; }
.image-item { width: 180rpx; height: 180rpx; border-radius: 12rpx; overflow: hidden; position: relative; }
.image-item image { width: 100%; height: 100%; }

.image-remove {
  position: absolute; top: -6rpx; right: -6rpx;
  width: 40rpx; height: 40rpx; background: #ff4d4f; color: #fff;
  border-radius: 50%; text-align: center; line-height: 36rpx; font-size: 30rpx;
}

.bottom-actions {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 30rpx; background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex; gap: 20rpx;
}

.bottom-actions button { flex: 1; margin: 0 !important; }

.info-row { display: flex; padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.info-row:last-child { border-bottom: none; }
.info-label { width: 180rpx; color: #999; font-size: 26rpx; flex-shrink: 0; }
.info-value { flex: 1; color: #333; font-size: 28rpx; line-height: 1.6; }

.role-tabs { display: flex; gap: 20rpx; }
.role-tab {
  flex: 1; padding: 24rpx; background: #f5f7fa; border-radius: 12rpx;
  text-align: center; font-size: 28rpx; border: 2rpx solid transparent;
}
.role-tab.active { background: #e6f7ff; border-color: #1890ff; color: #1890ff; font-weight: bold; }
