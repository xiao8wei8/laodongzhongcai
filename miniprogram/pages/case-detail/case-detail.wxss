.detail-container { padding: 20rpx 30rpx 60rpx; }

.case-title-lg { font-size: 34rpx; color: #1a1a1a; }

.info-row {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child { border-bottom: none; }

.info-label {
  width: 180rpx;
  flex-shrink: 0;
  color: #999;
  font-size: 26rpx;
}

.info-value {
  flex: 1;
  color: #333;
  font-size: 28rpx;
  line-height: 1.6;
}

.progress-item {
  display: flex;
  padding: 20rpx 0;
  position: relative;
}

.progress-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #d9d9d9;
  margin-right: 20rpx;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.progress-dot-active { background: #1890ff; }

.progress-content { flex: 1; }
.progress-title { font-size: 28rpx; font-weight: bold; color: #333; }
.progress-desc { margin-top: 8rpx; line-height: 1.5; }
.progress-time { margin-top: 8rpx; }

.message-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.message-item:last-child { border-bottom: none; }
