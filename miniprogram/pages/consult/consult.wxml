<view class="consult-container">
  <view wx:if="{{isGuestMode}}" class="empty-state">
    <view class="empty-state-icon">🔐</view>
    <view class="empty-state-text">登录后可提交咨询内容</view>
    <button class="btn-outline btn-sm mt-20" bindtap="goLogin">去登录</button>
  </view>

  <block wx:else>
  <view class="card">
    <view class="card-title">我要咨询</view>
    <view class="form-item">
      <text class="form-label form-label-required">咨询街道</text>
      <picker bindchange="onTenantChange" range="{{tenants}}" range-key="tenantName" value="{{tenantIndex}}">
        <view class="picker-view">{{tenantLabel}} <text class="text-muted">▼</text></view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label form-label-required">手机号</text>
      <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{form.phone}}" data-field="phone" bindinput="onInput" />
    </view>
    <view class="mediator-card" wx:if="{{form.tenantId}}">
      <view class="mediator-title">当前接收人</view>
      <view wx:if="{{mediatorLoading}}" class="text-muted text-sm">正在查询当前值班人员...</view>
      <block wx:elif="{{currentMediator}}">
        <view class="mediator-name">{{currentMediator.name}}</view>
        <view class="mediator-meta">{{currentMediator.role === 'tenant_admin' ? '街道管理员临时接收' : '值班调解员'}}{{currentMediator.phone ? ' · ' + currentMediator.phone : ''}}</view>
      </block>
      <view wx:else class="text-muted text-sm">当前街道暂未配置值班人员，提交后将由后台补充处理</view>
      <view class="mediator-hint" wx:if="{{mediatorHint}}">{{mediatorHint}}</view>
    </view>
  </view>

  <view class="card">
    <view class="card-title">咨询内容</view>
    <textarea class="form-textarea" placeholder="请输入您想咨询的问题，例如仲裁申请流程、材料准备、调解时效等" value="{{form.content}}" data-field="content" bindinput="onInput" maxlength="500" />
  </view>

  <view class="submit-placeholder"></view>
  <view wx:if="{{showBottomActions}}" class="bottom-actions page-fixed-entrance">
    <button class="btn-primary" loading="{{submitLoading}}" bindtap="submitConsultation">提交咨询</button>
  </view>
  </block>
</view>
