.consult-container {
  padding: 20rpx 30rpx 60rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: #f5f5f5;
}

.picker-view {
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.mediator-card {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  background: #f8fbff;
  border: 1rpx solid #d6e4ff;
}

.mediator-title {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-bottom: 12rpx;
}

.mediator-name {
  font-size: 32rpx;
  color: #1f1f1f;
  font-weight: 600;
}

.mediator-meta {
  font-size: 24rpx;
  color: #595959;
  margin-top: 8rpx;
}

.mediator-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #1890ff;
}

.submit-placeholder { height: 160rpx; }

.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
  z-index: 999;
  border-top: 1rpx solid #f0f0f0;
}

.bottom-actions button {
  width: 100%;
  margin: 0 !important;
}
