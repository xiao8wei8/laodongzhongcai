<view class="login-container">
  <view class="login-header">
    <view class="login-logo">⚖️</view>
    <view class="login-title">劳动仲裁调解系统</view>
    <view class="login-subtitle">便捷·高效·专业</view>
  </view>

  <view class="login-form card">
    <!-- 主按钮：微信快捷登录 -->
    <button class="btn-wechat" loading="{{loading}}" disabled="{{loading}}" bindtap="onWechatLogin">
      <text class="wechat-icon">💬</text> 微信快捷登录
    </button>

    <view class="divider">
      <view class="divider-line"></view>
      <text class="divider-text">或使用账号密码</text>
      <view class="divider-line"></view>
    </view>

    <view class="form-item">
      <text class="form-label">账号</text>
      <input class="form-input" placeholder="请输入用户名/手机号" value="{{username}}" bindinput="onUsernameInput" />
    </view>

    <view class="form-item">
      <text class="form-label">密码</text>
      <input class="form-input" placeholder="请输入密码" password value="{{password}}" bindinput="onPasswordInput" />
    </view>

    <view class="form-item">
      <text class="form-label">用户类型</text>
      <view class="role-tabs">
        <view class="role-tab {{role === 'personal' ? 'active' : ''}}" data-role="personal" bindtap="onRoleChange">
          <text class="role-emoji">👤</text>
          <text class="role-text">个人用户</text>
        </view>
        <view class="role-tab {{role === 'company' ? 'active' : ''}}" data-role="company" bindtap="onRoleChange">
          <text class="role-emoji">🏢</text>
          <text class="role-text">企业用户</text>
        </view>
      </view>
    </view>

    <button class="btn-primary" loading="{{loading}}" disabled="{{loading}}" bindtap="onLogin">
      登 录
    </button>

    <view class="login-links">
      <text bindtap="goRegister">还没有账号？立即注册</text>
    </view>
  </view>

  <view class="login-footer">
    <text class="text-muted text-sm">登录即表示同意《用户协议》和《隐私政策》</text>
  </view>
</view>
