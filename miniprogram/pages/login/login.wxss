.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #e6f7ff 0%, #f5f5f5 60%);
  padding: 60rpx 40rpx 60rpx;
  box-sizing: border-box;
}

.login-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.login-logo {
  font-size: 140rpx;
  line-height: 1;
  margin-bottom: 30rpx;
}

.login-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 14rpx;
  letter-spacing: 2rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: #666666;
  letter-spacing: 4rpx;
}

/* 登录卡片 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(24, 144, 255, 0.08);
}

.login-form {
  margin-top: 20rpx;
}

.login-guide {
  margin-bottom: 24rpx;
}

.guide-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.guide-text {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.8;
}

.btn-browse {
  margin-top: 24rpx;
  border-radius: 16rpx;
  background: #f0f7ff;
  color: #1677ff;
  border: 2rpx solid #bfdbfe;
}

.btn-browse::after {
  border: none;
}

/* 微信主登录按钮：绿色，更醒目 */
.btn-wechat {
  background: linear-gradient(90deg, #07c160 0%, #06ad56 100%) !important;
  color: #fff !important;
  font-size: 34rpx;
  font-weight: 500;
  border-radius: 50rpx;
  padding: 28rpx 0;
  margin-bottom: 40rpx;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(7, 193, 96, 0.25);
}

.btn-wechat::after {
  border: none;
}

.wechat-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

.wechat-login-tip {
  margin-top: 12rpx;
  text-align: center;
  color: #8c8c8c;
  font-size: 24rpx;
}

.role-selector-only {
  margin-bottom: 40rpx;
}

/* 分割线 */
.divider {
  display: flex;
  align-items: center;
  margin: 20rpx 0 40rpx;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: #e8e8e8;
}

.divider-text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #999;
}

/* 表单字段（增加上下间距） */
.form-item {
  margin-bottom: 36rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  box-sizing: border-box;
  height: 96rpx;
  padding: 0 28rpx;
  background: #f5f7fa;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #1a1a1a;
}

.form-input:focus {
  background: #ffffff;
  border-color: #1890ff;
}

.picker-display {
  width: 100%;
  box-sizing: border-box;
  min-height: 96rpx;
  line-height: 96rpx;
  padding: 0 28rpx;
  background: #f5f7fa;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #1a1a1a;
}

.picker-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow {
  color: #999;
  font-size: 24rpx;
}

/* 用户类型选择卡片 */
.role-tabs {
  display: flex;
  gap: 20rpx;
}

.role-tab {
  flex: 1;
  padding: 36rpx 20rpx;
  background: #f5f7fa;
  border-radius: 16rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.role-tab.active {
  background: #e6f7ff;
  border-color: #1890ff;
}

.role-emoji {
  font-size: 56rpx;
  display: block;
  margin-bottom: 12rpx;
}

.role-text {
  font-size: 28rpx;
  color: #333;
}

.role-tab.active .role-text {
  color: #1890ff;
  font-weight: bold;
}

/* 登录按钮 */
.btn-primary {
  background: linear-gradient(90deg, #1890ff 0%, #096dd9 100%) !important;
  color: #fff !important;
  font-size: 34rpx;
  font-weight: 500;
  border-radius: 50rpx;
  padding: 28rpx 0;
  margin-top: 20rpx;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(24, 144, 255, 0.25);
}

.btn-primary::after {
  border: none;
}

/* 底部注册链接 */
.login-links {
  text-align: center;
  margin-top: 40rpx;
}

.login-links text {
  color: #1890ff;
  font-size: 28rpx;
}

/* 页脚协议 */
.login-footer {
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.text-muted {
  color: #999;
}

.text-sm {
  font-size: 24rpx;
}

.agreement-row {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  line-height: 1.6;
  flex-wrap: wrap;
}

.agreement-checkbox {
  transform: scale(0.9);
}

.agreement-link {
  color: #1677ff;
}

.agreement-tip {
  margin-top: 16rpx;
  color: #94a3b8;
  font-size: 24rpx;
  text-align: center;
}

.tenant-panel-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.42);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.tenant-panel {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 28rpx 40rpx;
  box-sizing: border-box;
}

.tenant-panel-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 24rpx;
}

.tenant-search-input {
  width: 100%;
  height: 84rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #f5f7fa;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.tenant-list {
  max-height: 700rpx;
}

.tenant-item {
  padding: 24rpx 20rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  margin-bottom: 16rpx;
  border: 2rpx solid transparent;
}

.tenant-item.active {
  border-color: #1890ff;
  background: #e6f7ff;
}

.tenant-item-name {
  font-size: 30rpx;
  color: #1f1f1f;
  font-weight: 500;
}

.tenant-item-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8c8c8c;
}

.tenant-empty {
  padding: 40rpx 0;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.tenant-close-btn {
  margin-top: 16rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  color: #333;
}

.tenant-close-btn::after {
  border: none;
}

.sms-bind-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 18rpx;
}

.sms-input {
  width: 100%;
  box-sizing: border-box;
  height: 84rpx;
  background: #fff;
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 2rpx solid #edf2f7;
}
