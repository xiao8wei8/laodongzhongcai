.messages-container { padding: 20rpx 30rpx 60rpx; }

.tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
}

.tab { flex: 1; text-align: center; padding: 20rpx; font-size: 28rpx; color: #666; border-radius: 12rpx; }
.tab.active { background: #e6f7ff; color: #1890ff; font-weight: bold; }

.broadcast-card, .message-card { margin-bottom: 20rpx; }

.broadcast-image-wrap {
  margin-top: 18rpx;
}

.broadcast-image {
  width: 100%;
  border-radius: 16rpx;
  background: #f5f5f5;
}
