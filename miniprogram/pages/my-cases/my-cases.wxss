.cases-container { padding: 20rpx 30rpx 120rpx; }
.search-bar { display: flex; align-items: center; padding: 20rpx 30rpx; margin-bottom: 20rpx; }
.search-input { flex: 1; font-size: 28rpx; padding: 10rpx 20rpx; background: #f5f7fa; border-radius: 40rpx; }
.search-btn { padding-left: 20rpx; font-size: 32rpx; }

.filter-tabs {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 10rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 12rpx;
}

.filter-tab.active { background: #e6f7ff; color: #1890ff; font-weight: bold; }

.case-card { margin-bottom: 20rpx; }
.case-number { font-size: 30rpx; }
.case-title { font-size: 28rpx; color: #333; }

.fab {
  position: fixed; right: 40rpx; bottom: 60rpx;
  width: 100rpx; height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1890ff, #096dd9);
  color: #ffffff;
  font-size: 60rpx;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.4);
  z-index: 999;
}
