.profile-container { padding: 20rpx 30rpx 120rpx; }

.profile-header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 60rpx 30rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx; font-weight: bold;
  margin-right: 30rpx;
}

.avatar-image { margin-right: 0; background: #fff; }

.avatar-btn {
  padding: 0;
  margin: 0 30rpx 0 0;
  background: transparent;
  line-height: 1;
  border: none;
}

.avatar-btn::after { border: none; }

.profile-info { flex: 1; color: #fff; }
.profile-name { font-size: 36rpx; font-weight: bold; margin-bottom: 10rpx; }
.profile-role { color: rgba(255, 255, 255, 0.85); }
.profile-phone { margin-top: 12rpx; color: rgba(255, 255, 255, 0.92); font-size: 24rpx; }

.bind-phone-btn {
  margin: 16rpx 0 0;
  width: 220rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  color: #096dd9;
  background: #fff;
  border-radius: 28rpx;
}

.bind-phone-btn::after { border: none; }

.phone-bind-panel {
  margin-bottom: 20rpx;
  padding: 28rpx;
}

.phone-bind-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 18rpx;
}

.phone-bind-input {
  width: 100%;
  height: 84rpx;
  box-sizing: border-box;
  background: #f8fafc;
  border-radius: 14rpx;
  border: 2rpx solid #edf2f7;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.phone-bind-picker {
  width: 100%;
  min-height: 84rpx;
  line-height: 84rpx;
  box-sizing: border-box;
  background: #f8fafc;
  border-radius: 14rpx;
  border: 2rpx solid #edf2f7;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1f1f1f;
}

.phone-bind-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.phone-bind-code {
  flex: 1;
}

.phone-send-btn {
  width: 220rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 14rpx;
  background: #e6f7ff;
  color: #096dd9;
  font-size: 26rpx;
  padding: 0;
}

.phone-send-btn::after {
  border: none;
}

.phone-bind-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.phone-bind-cancel,
.phone-bind-confirm {
  flex: 1;
  border-radius: 14rpx;
  font-size: 28rpx;
}

.phone-bind-cancel {
  background: #f5f5f5;
  color: #666;
}

.phone-bind-confirm {
  background: linear-gradient(90deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
}

.phone-bind-cancel::after,
.phone-bind-confirm::after {
  border: none;
}

.stats-card { display: flex; padding: 40rpx 30rpx; }
.stats-item { flex: 1; text-align: center; }
.stats-num { font-size: 48rpx; font-weight: bold; color: #1890ff; }
.stats-label { font-size: 24rpx; color: #666; margin-top: 8rpx; }

.menu-card { padding: 20rpx 30rpx; margin-bottom: 20rpx; }
.menu-item {
  display: flex; align-items: center;
  padding: 30rpx 0; border-bottom: 1rpx solid #f5f5f5;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; width: 60rpx; text-align: center; }
.menu-text { flex: 1; font-size: 28rpx; color: #333; }
.menu-text-wrap { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.menu-subtext { font-size: 22rpx; color: #999; }
.menu-arrow { color: #ccc; font-size: 40rpx; }

.logout-btn {
  background: #fff; color: #ff4d4f;
  border-radius: 12rpx; margin-top: 40rpx; font-size: 30rpx;
}
